{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "aetheron-iot",
  "compatibility_date": "2026-05-31",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "public",
    "binding": "ASSETS"
  },
  "build": {
    "command": "hugo --gc --minify",
    "watch_dir": "content"
  }
}